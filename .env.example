# Telegram bot
BOT_TOKEN=your_telegram_bot_token_here

# Access control (optional, comma-separated tg user ids)
ALLOWED_USER_IDS=

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://freelance:freelance@db:5432/freelance_bot

# Scraping
SCRAPE_INTERVAL=300
SCRAPE_ENABLED=true
USE_PLAYWRIGHT=true

# LLM classification (Groq — OpenAI-compatible, high rate limits)
LLM_API_KEY=your_groq_key
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant
LLM_ENABLED=true

# HTTP
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0 Safari/537.36

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
WEB_BASE_URL=http://localhost:8000

# Telegram bot
BOT_TOKEN=your_telegram_bot_token_here

# Access control (optional, comma-separated tg user ids)
ALLOWED_USER_IDS=

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://freelance:freelance@db:5432/freelance_bot

# Scraping
SCRAPE_INTERVAL=300
SCRAPE_ENABLED=true
USE_PLAYWRIGHT=true

# LLM classification (OpenRouter / DeepSeek)
LLM_API_KEY=your_openrouter_key
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=poolside/laguna-xs-2.1:free
LLM_ENABLED=true

# HTTP
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0 Safari/537.36

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
